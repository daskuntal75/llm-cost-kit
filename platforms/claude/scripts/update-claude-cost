#!/bin/zsh
# =============================================================================
# update-claude-cost — v3.5.2
#   Two-pool model: subscription (flat fee) + api_pool (everything else)
#   subscription.extra_usage_enabled is a simple boolean (not a separate pool)
#   Auto-migrates from v3.4.x and v3.5.x
#
# Setup:
#   chmod +x update-claude-cost
#   cp update-claude-cost ~/.local/bin/
#   export SKILLS_SOURCE_DIR=~/dev/skills-source   # add to ~/.zshrc
#
# Wire into hourly LaunchAgent:
#   update-claude-cost --code && update-claude-cost --pull-api-spend && \
#   update-claude-cost --emit-l7 && update-claude-cost --emit-l2 && \
#   update-claude-cost --emit-l3-global
# =============================================================================

set -e
COST_FILE=~/.claude/cumulative-cost.json
ARCHIVE_DIR=~/.claude/cost-archive
HELPER_DIR=~/.local/bin
SKILLS_SOURCE_DIR="${SKILLS_SOURCE_DIR:-$HOME/dev/skills-source}"
mkdir -p ~/.claude "$ARCHIVE_DIR"

# Initialize fresh v3.5.2 schema
if [[ ! -f "$COST_FILE" ]]; then
  CURRENT_MONTH=$(date +%Y-%m)
  cat > "$COST_FILE" << JSONEOF
{
  "month": "$CURRENT_MONTH",
  "schema_version": "3.5.2",
  "subscription": {
    "plan": "YOUR_PLAN_NAME",
    "monthly_fee_usd": 0,
    "renewal_date": null,
    "extra_usage_enabled": false,
    "session_limit": {"percent_used": 0, "resets_at": null, "last_updated": null},
    "weekly_all_models": {"percent_used": 0, "resets_at": null, "last_updated": null},
    "weekly_sonnet_only": {"percent_used": 0, "resets_at": null, "last_updated": null},
    "throttle_events": [],
    "throttle_hits_mtd": 0,
    "throttle_hits_since_last_reset": 0,
    "throttle_breakdown_since_reset": {"usage_limit": 0, "tool_limit": 0},
    "window_started_at": null,
    "next_reset_at": null,
    "total_downtime_mtd_minutes": 0
  },
  "api_pool": {
    "tier_name": null,
    "tier_ceiling": 0.00,
    "customer_limit": 0.00,
    "current_spend": 0.00,
    "credit_balance": 0.00,
    "auto_reload_threshold": 0,
    "auto_reload_amount": 0,
    "alerts_at": [],
    "resets_on": null,
    "rate_limits": {"rpm": 0, "input_tpm": 0, "output_tpm": 0},
    "admin_api_key_set": false,
    "last_updated": null
  },
  "value_signal": {
    "ccusage_mtd": 0.00,
    "ratio_to_plan_fee": 0.00,
    "verdict": "no data",
    "downgrade_candidate": false
  },
  "tier_test": {
    "last_test": null, "next_check": null, "candidate_plan": null,
    "candidate_fee": null, "test_status": "none"
  }
}
JSONEOF
  echo "Initialized v3.5.2 schema at $COST_FILE"
  echo "Run: update-claude-cost --plan <name> --fee <amount> --renews <YYYY-MM-DD>"
fi

# Migrate from v3.4.x or v3.5.0/v3.5.1 → v3.5.2
migrate() {
  SCHEMA=$(jq -r '.schema_version // "unknown"' "$COST_FILE")
  if [[ "$SCHEMA" == "3.5.2" ]]; then
    return 0
  fi

  echo "▸ Migrating $SCHEMA → 3.5.2"
  cp "$COST_FILE" "$ARCHIVE_DIR/cumulative-cost-pre-3.5.2-$(date +%Y%m%d-%H%M%S).json"

  jq '
    .schema_version = "3.5.2"
    | .subscription.extra_usage_enabled //= (.extra_usage.enabled // false)
    | .subscription.session_limit //= {"percent_used": 0, "resets_at": null, "last_updated": null}
    | .subscription.weekly_all_models //= {"percent_used": 0, "resets_at": null, "last_updated": null}
    | .subscription.weekly_sonnet_only //= {"percent_used": 0, "resets_at": null, "last_updated": null}
    | (if .api_direct then .api_pool = .api_direct else . end)
    | (if .api_pool == null then
        .api_pool = {
          "tier_name": null, "tier_ceiling": 0, "customer_limit": 0,
          "current_spend": 0, "credit_balance": 0,
          "auto_reload_threshold": 0, "auto_reload_amount": 0,
          "alerts_at": [], "resets_on": null,
          "rate_limits": {"rpm": 0, "input_tpm": 0, "output_tpm": 0},
          "admin_api_key_set": false, "last_updated": null
        }
       else . end)
    | del(.extra_usage)
    | del(.api_direct)
  ' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"

  echo "✓ Migrated to v3.5.2"
}
migrate

# New month detection
CURRENT_MONTH=$(date +%Y-%m)
STORED_MONTH=$(jq -r .month "$COST_FILE")
if [[ "$STORED_MONTH" != "$CURRENT_MONTH" && "$1" != "--reset" && "$1" != "--monthly-review" && "$1" != "--migrate" ]]; then
  echo "⚠ New month: stored=$STORED_MONTH, current=$CURRENT_MONTH. Run --monthly-review then --reset."
  exit 1
fi

# Auto-clear expired throttle reset window
NEXT_RESET=$(jq -r '.subscription.next_reset_at // "null"' "$COST_FILE")
if [[ "$NEXT_RESET" != "null" && "$NEXT_RESET" != "" ]]; then
  EXPIRED=$(python3 -c "
from datetime import datetime, timezone
try:
    rst = datetime.fromisoformat('$NEXT_RESET'.replace('Z', '+00:00'))
    print(1 if datetime.now(timezone.utc) > rst else 0)
except Exception:
    print(0)
")
  if [[ "$EXPIRED" == "1" ]]; then
    jq '.subscription.throttle_hits_since_last_reset = 0
        | .subscription.throttle_breakdown_since_reset = {"usage_limit": 0, "tool_limit": 0}
        | .subscription.window_started_at = null
        | .subscription.next_reset_at = null' \
       "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
  fi
fi

# Recompute verdict
recompute() {
  CCUSAGE=$(jq .value_signal.ccusage_mtd "$COST_FILE")
  FEE=$(jq .subscription.monthly_fee_usd "$COST_FILE")
  THROTTLE=$(jq .subscription.throttle_hits_mtd "$COST_FILE")
  DOWNTIME=$(jq .subscription.total_downtime_mtd_minutes "$COST_FILE")

  if (( $(python3 -c "print(1 if $FEE == 0 else 0)") )); then RATIO="0.00"
  else RATIO=$(python3 -c "print(round($CCUSAGE / $FEE, 2))"); fi

  if (( $(python3 -c "print(1 if $CCUSAGE == 0 else 0)") )); then
    VERDICT="no data — run --code"; DOWNGRADE="false"
  elif (( $(python3 -c "print(1 if $RATIO < 0.5 else 0)") )); then
    VERDICT="STRONG DOWNGRADE"; DOWNGRADE="true"
  elif (( $(python3 -c "print(1 if $RATIO < 1.0 else 0)") )); then
    VERDICT="BELOW BREAK-EVEN"; DOWNGRADE="true"
  elif (( $(python3 -c "print(1 if $RATIO < 3.0 else 0)") )); then
    VERDICT="PLAN JUSTIFIED"; DOWNGRADE="false"
  elif (( $(python3 -c "print(1 if $THROTTLE >= 3 or $DOWNTIME >= 500 else 0)") )); then
    VERDICT="PLAN CORRECTLY SIZED"; DOWNGRADE="false"
  elif (( $(python3 -c "print(1 if $THROTTLE > 0 else 0)") )); then
    VERDICT="WORKING WELL"; DOWNGRADE="false"
  else
    VERDICT="DOWNGRADE CANDIDATE"; DOWNGRADE="true"
  fi

  jq --argjson r "$RATIO" --arg v "$VERDICT" --argjson d "$([ "$DOWNGRADE" = "true" ] && echo true || echo false)" \
     '.value_signal.ratio_to_plan_fee = $r | .value_signal.verdict = $v | .value_signal.downgrade_candidate = $d' \
     "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
}

to_iso_timestamp() {
  local input="$1"
  if [[ "$input" =~ ^[0-9]{2}:[0-9]{2}$ ]]; then
    echo "$(date +%Y-%m-%dT${input}:00%z | sed 's/\([+-][0-9][0-9]\)\([0-9][0-9]\)/\1:\2/')"
  elif [[ "$input" =~ ^([0-9]+)h\ ?([0-9]*)m?$ ]]; then
    HRS="${match[1]}"; MIN="${match[2]:-0}"
    [[ -z "$MIN" ]] && MIN=0
    python3 -c "
from datetime import datetime, timezone, timedelta
print((datetime.now(timezone.utc) + timedelta(hours=$HRS, minutes=$MIN)).strftime('%Y-%m-%dT%H:%M:%SZ'))"
  else echo "$input"; fi
}

record_throttle() {
  local TYPE="usage_limit" SURFACE="unknown" RESET_AT="" CONTEXT=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type) TYPE="$2"; shift 2 ;;
      --surface) SURFACE="$2"; shift 2 ;;
      --reset-at) RESET_AT=$(to_iso_timestamp "$2"); shift 2 ;;
      --context) CONTEXT="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [[ "$TYPE" != "usage_limit" && "$TYPE" != "tool_limit" ]]; then
    echo "✗ Invalid --type: $TYPE"; return 1
  fi

  local NOW=$(date -u +%Y-%m-%dT%H:%M:%SZ) DOWNTIME=0
  if [[ -n "$RESET_AT" ]]; then
    DOWNTIME=$(python3 -c "
from datetime import datetime
try:
    now = datetime.fromisoformat('$NOW'.replace('Z','+00:00'))
    rst = datetime.fromisoformat('$RESET_AT'.replace('Z','+00:00'))
    print(max(0, int((rst - now).total_seconds() / 60)))
except Exception: print(0)")
  fi

  EXISTING_RESET=$(jq -r '.subscription.next_reset_at // "null"' "$COST_FILE")
  if [[ "$EXISTING_RESET" == "null" || "$EXISTING_RESET" == "" ]]; then
    jq --arg ts "$NOW" --arg surf "$SURFACE" --arg rst "$RESET_AT" --argjson dt "$DOWNTIME" --arg ctx "$CONTEXT" --arg t "$TYPE" \
       '.subscription.throttle_events += [{"timestamp": $ts, "type": $t, "surface": $surf, "reset_at": ($rst | if . == "" then null else . end), "downtime_minutes": $dt, "context": ($ctx | if . == "" then null else . end)}]
        | .subscription.throttle_hits_mtd += 1
        | .subscription.throttle_hits_since_last_reset = 1
        | .subscription.throttle_breakdown_since_reset[$t] = 1
        | .subscription.window_started_at = $ts
        | .subscription.next_reset_at = ($rst | if . == "" then null else . end)
        | .subscription.total_downtime_mtd_minutes += $dt' \
       "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
    echo "✓ Throttle ($TYPE, $SURFACE) — new reset window"
  else
    jq --arg ts "$NOW" --arg surf "$SURFACE" --arg rst "$RESET_AT" --argjson dt "$DOWNTIME" --arg ctx "$CONTEXT" --arg t "$TYPE" \
       '.subscription.throttle_events += [{"timestamp": $ts, "type": $t, "surface": $surf, "reset_at": ($rst | if . == "" then null else . end), "downtime_minutes": $dt, "context": ($ctx | if . == "" then null else . end)}]
        | .subscription.throttle_hits_mtd += 1
        | .subscription.throttle_hits_since_last_reset += 1
        | .subscription.throttle_breakdown_since_reset[$t] += 1
        | .subscription.total_downtime_mtd_minutes += $dt' \
       "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
    echo "✓ Throttle ($TYPE) — total since reset: $(jq -r .subscription.throttle_hits_since_last_reset $COST_FILE)"
  fi
}

monthly_review() {
  echo "════════════════════════════════════════════════════"
  echo "  Monthly Review — $(jq -r .month $COST_FILE)"
  echo "════════════════════════════════════════════════════"
  jq -r '
    "Plan:           \(.subscription.plan) at $\(.subscription.monthly_fee_usd)/mo (renews \(.subscription.renewal_date // "?"))",
    "ccusage MTD:    $\(.value_signal.ccusage_mtd) (\(.value_signal.ratio_to_plan_fee)× plan fee)",
    "Throttle:       \(.subscription.throttle_hits_mtd) hits, \(.subscription.total_downtime_mtd_minutes) min downtime",
    "Verdict:        \(.value_signal.verdict)",
    "API pool:       $\(.api_pool.current_spend) of $\(.api_pool.customer_limit) cap (\(.api_pool.tier_name // "?"))"
  ' "$COST_FILE"
}

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --code)
      command -v ccusage &>/dev/null || { echo "ccusage not installed — see https://github.com/ryoppippi/ccusage"; exit 1; }
      MTD=$(ccusage --since "$(date +%Y%m01)" --until "$(date +%Y%m%d)" --json 2>/dev/null \
            | jq -r '.totals.totalCost // 0' 2>/dev/null \
            | python3 -c "import sys; v=sys.stdin.read().strip(); print(round(float(v) if v and v != 'null' else 0, 2))" 2>/dev/null \
            || echo "0.00")
      [[ -z "$MTD" || "$MTD" == "null" ]] && MTD="0.00"
      jq --argjson mtd "$MTD" '.value_signal.ccusage_mtd = $mtd' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      echo "✓ ccusage MTD: \$$MTD"
      shift ;;
    --pull-api-spend)
      [[ ! -f "$HELPER_DIR/admin-api-pull.py" ]] && { echo "✗ admin-api-pull.py not found in $HELPER_DIR"; exit 1; }
      python3 "$HELPER_DIR/admin-api-pull.py" "$COST_FILE"
      shift ;;
    --plan)        jq --arg p "$2" '.subscription.plan = $p' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --fee)         jq --argjson v "$2" '.subscription.monthly_fee_usd = $v' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --renews)      jq --arg d "$2" '.subscription.renewal_date = $d' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --extra-enabled)
      VAL=$([ "$2" = "true" ] && echo true || echo false)
      jq --argjson v "$VAL" '.subscription.extra_usage_enabled = $v' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --session-percent)
      jq --argjson v "$2" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
         '.subscription.session_limit.percent_used = $v | .subscription.session_limit.last_updated = $ts' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --resets-in)
      RST_TS=$(to_iso_timestamp "$2")
      jq --arg t "$RST_TS" '.subscription.session_limit.resets_at = $t' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --weekly-all)
      jq --argjson v "$2" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
         '.subscription.weekly_all_models.percent_used = $v | .subscription.weekly_all_models.last_updated = $ts' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --weekly-sonnet)
      jq --argjson v "$2" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
         '.subscription.weekly_sonnet_only.percent_used = $v | .subscription.weekly_sonnet_only.last_updated = $ts' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --weekly-resets)
      jq --arg s "$2" '.subscription.weekly_all_models.resets_at = $s | .subscription.weekly_sonnet_only.resets_at = $s' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --api-spend)
      jq --argjson v "$2" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
         '.api_pool.current_spend = $v | .api_pool.last_updated = $ts' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;
    --api-limit)        jq --argjson v "$2" '.api_pool.customer_limit = $v' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --api-tier)         jq --arg t "$2" '.api_pool.tier_name = $t' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --api-tier-ceiling) jq --argjson v "$2" '.api_pool.tier_ceiling = $v' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --api-balance)      jq --argjson v "$2" '.api_pool.credit_balance = $v' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;
    --api-resets)       jq --arg d "$2" '.api_pool.resets_on = $d' "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"; shift 2 ;;

    --throttle)
      shift; record_throttle "$@"
      while [[ $# -gt 0 && "$1" =~ ^-- ]]; do
        case "$1" in --type|--surface|--reset-at|--context) shift 2 ;; *) shift ;; esac
      done ;;

    --tier-test)
      NEXT=$(date -v+1m +%Y-%m-%d 2>/dev/null || date -d '+1 month' +%Y-%m-%d)
      jq --arg p "$2" --arg d "$NEXT" \
         '.tier_test.candidate_plan = $p | .tier_test.next_check = $d | .tier_test.test_status = "in-progress" | .tier_test.last_test = (now | todate)' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift 2 ;;

    --monthly-review) monthly_review; exit 0 ;;
    --migrate) shift ;;

    --emit-l7)
      L7_DIR="${SKILLS_SOURCE_DIR}/chat-instructions"
      [[ ! -d "$L7_DIR" ]] && { echo "✗ $L7_DIR not found — set SKILLS_SOURCE_DIR or create directory"; shift; continue; }
      [[ ! -f "$HELPER_DIR/emit-l7-helper.py" ]] && { echo "✗ emit-l7-helper.py not found in $HELPER_DIR"; shift; continue; }
      python3 "$HELPER_DIR/emit-l7-helper.py" "$COST_FILE" "$L7_DIR"
      shift ;;

    --emit-l2)
      L2_FILE="${SKILLS_SOURCE_DIR}/cowork-instructions/_global.md"
      [[ ! -f "$HELPER_DIR/emit-l7-helper.py" ]] && { echo "✗ emit-l7-helper.py not found in $HELPER_DIR"; shift; continue; }
      python3 "$HELPER_DIR/emit-l7-helper.py" "$COST_FILE" - --l2 "$L2_FILE"
      shift ;;

    --emit-l3-global)
      L3G_FILE="${HOME}/.claude/CLAUDE.md"
      [[ ! -f "$HELPER_DIR/emit-l7-helper.py" ]] && { echo "✗ emit-l7-helper.py not found in $HELPER_DIR"; shift; continue; }
      python3 "$HELPER_DIR/emit-l7-helper.py" "$COST_FILE" - --l3-global "$L3G_FILE"
      shift ;;

    --reset)
      cp "$COST_FILE" "$ARCHIVE_DIR/cumulative-cost-$(date +%Y-%m-%d).json"
      jq --arg m "$CURRENT_MONTH" \
         '.month = $m | .value_signal.ccusage_mtd = 0
          | .subscription.throttle_hits_mtd = 0
          | .subscription.throttle_hits_since_last_reset = 0
          | .subscription.throttle_breakdown_since_reset = {"usage_limit": 0, "tool_limit": 0}
          | .subscription.window_started_at = null | .subscription.next_reset_at = null
          | .subscription.total_downtime_mtd_minutes = 0
          | .subscription.throttle_events = []
          | .api_pool.current_spend = 0' \
         "$COST_FILE" > "$COST_FILE.tmp" && mv "$COST_FILE.tmp" "$COST_FILE"
      shift ;;

    *) shift ;;
  esac
done

recompute

echo ""
echo "════ Claude cost — month $(jq -r .month $COST_FILE) (v3.5.2) ════"
echo ""
echo "▸ Subscription"
jq -r '"  Plan: \(.subscription.plan) @ $\(.subscription.monthly_fee_usd)/mo · Renews: \(.subscription.renewal_date // "?") · Extra usage: \(if .subscription.extra_usage_enabled then "ON" else "OFF" end)",
       "  Session: \(.subscription.session_limit.percent_used)% (resets: \(.subscription.session_limit.resets_at // "?"))",
       "  Weekly: \(.subscription.weekly_all_models.percent_used)% all-models, \(.subscription.weekly_sonnet_only.percent_used)% sonnet (resets: \(.subscription.weekly_all_models.resets_at // "?"))",
       "  Throttle MTD: \(.subscription.throttle_hits_mtd) (\(.subscription.total_downtime_mtd_minutes) min)",
       "  Throttle since reset: \(.subscription.throttle_hits_since_last_reset) (usage: \(.subscription.throttle_breakdown_since_reset.usage_limit), tool: \(.subscription.throttle_breakdown_since_reset.tool_limit))"' "$COST_FILE"

echo ""
echo "▸ API pool (all pay-as-you-go)"
jq -r '"  \(.api_pool.tier_name // "?") · $\(.api_pool.current_spend) of $\(.api_pool.customer_limit) cap · Tier ceiling: $\(.api_pool.tier_ceiling)",
       "  Balance: $\(.api_pool.credit_balance) (auto-reload: $\(.api_pool.auto_reload_threshold) → $\(.api_pool.auto_reload_amount)) · Resets: \(.api_pool.resets_on // "?")",
       "  Admin API: \(.api_pool.admin_api_key_set) · Last updated: \(.api_pool.last_updated // "never")"' "$COST_FILE"

echo ""
echo "▸ Subscription value (ccusage retail-equivalent)"
jq -r '"  $\(.value_signal.ccusage_mtd) (\(.value_signal.ratio_to_plan_fee)× plan fee) · \(.value_signal.verdict)"' "$COST_FILE"

THROTTLE_COUNT=$(jq '.subscription.throttle_events | length' "$COST_FILE")
if [[ "$THROTTLE_COUNT" -gt 0 ]]; then
  echo ""
  echo "▸ Recent throttles (last 5)"
  jq -r '.subscription.throttle_events[-5:] | reverse | .[] | "  \(.timestamp[0:16]) · \(.type) · \(.surface) · \(.downtime_minutes)min"' "$COST_FILE"
fi

echo ""
